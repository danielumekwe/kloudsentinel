# Sentinel bare-metal production configuration.
#
# Copied to /etc/sentinel/sentinel.env by scripts/install.sh (chmod 600,
# never overwritten on re-run). Every value below is read directly by
# src/sentinel/config.py's Settings class via the SENTINEL_ env prefix.
#
# Unlike the Docker deployment, there is no /host/... path remapping here —
# these are real absolute paths on this machine, which is why most of the
# host-path settings below already match config.py's own defaults. They are
# listed explicitly anyway so every knob is visible and overridable without
# reading source.

SENTINEL_ENVIRONMENT=production
SENTINEL_LOG_LEVEL=INFO

# v1 default: auto-quarantine is live (CRITICAL findings only, capped per
# account per run — see SENTINEL_AUTO_QUARANTINE_MAX_PER_ACCOUNT_PER_RUN
# below). To roll back, set to "manual" (remediation stays human-triggered
# via the API/CLI) or "observe" (every mutation endpoint returns 403), then
# `systemctl restart sentinel-api sentinel-worker` — takes effect
# immediately, no code change. Quarantine is always reversible via
# `sentinel restore` / `sentinel quarantine restore`, so a bad
# auto-quarantine decision is never data loss. See
# docs/architecture/decisions/0001-v1-deployment-privilege-and-mode.md.
SENTINEL_MODE=active

# The only required override versus config.py's defaults (which assume a
# Docker volume mounted at /data).
SENTINEL_DATABASE_URL=sqlite+aiosqlite:////var/lib/sentinel/sentinel.db
SENTINEL_DATABASE_ECHO=false

# Where quarantined files are moved to — deliberately outside every
# account's home directory so they're invisible to future scans and
# unreachable by the web server. Already config.py's default; explicit
# here for visibility.
SENTINEL_QUARANTINE_ROOT_DIRECTORY=/var/lib/sentinel/quarantine

# Real host paths this box actually uses for a cPanel/WHM install. All
# already match config.py's defaults — override only if this server's
# layout differs.
SENTINEL_CPANEL_ETC_DIRECTORY=/etc
SENTINEL_CPANEL_HOME_BASE_DIRECTORY=/home
SENTINEL_CPANEL_SUSPENDED_DIRECTORY=/var/cpanel/suspended
SENTINEL_PROC_DIRECTORY=/proc
SENTINEL_VAR_LOG_DIRECTORY=/var/log
SENTINEL_CPANEL_BINARIES_DIRECTORY=/usr/local/cpanel
SENTINEL_FORENSICS_TEMP_DIRECTORIES='["/tmp","/var/tmp","/dev/shm"]'
SENTINEL_WORDPRESS_CRONTAB_DIRECTORY=/var/spool/cron

# Scheduled job intervals (minutes) — defaults shown, override to tune.
SENTINEL_DISCOVERY_SCAN_INTERVAL_MINUTES=360
SENTINEL_INTEGRITY_SCAN_INTERVAL_MINUTES=60
SENTINEL_INVENTORY_SCAN_INTERVAL_MINUTES=240
SENTINEL_MONITORING_SCAN_INTERVAL_MINUTES=30
SENTINEL_LOG_INGESTION_INTERVAL_MINUTES=2
SENTINEL_FORENSICS_SCAN_INTERVAL_MINUTES=5
SENTINEL_CORRELATION_INTERVAL_MINUTES=5
SENTINEL_WORDPRESS_INVENTORY_SCAN_INTERVAL_MINUTES=240
SENTINEL_WORDPRESS_INTEGRITY_AUDIT_INTERVAL_MINUTES=60
SENTINEL_WORDPRESS_FORENSIC_SCAN_INTERVAL_MINUTES=15

# Auto-quarantine circuit breaker: caps how many CRITICAL findings one
# account can have auto-quarantined per run; beyond the cap, the rest are
# left untouched (safe) and one alert event is raised instead of
# continuing unattended.
SENTINEL_AUTO_QUARANTINE_MAX_PER_ACCOUNT_PER_RUN=5
SENTINEL_AUTO_QUARANTINE_INTERVAL_MINUTES=20

# Used by the CLI's own `sentinel health`/`doctor` commands to reach the
# API on this same box.
SENTINEL_API_BASE_URL=http://localhost:8443

# WHM plugin bridge — only relevant on a WHM host. install.sh appends both
# of these automatically (generating the secret into
# /etc/sentinel/whm-plugin.secret) when it detects /usr/local/cpanel; left
# commented here since a non-WHM install has no use for them.
# SENTINEL_WHM_PLUGIN_SHARED_SECRET=
# SENTINEL_DASHBOARD_BASE_PATH=/cgi/kloudsentinel/index.cgi
